// schema.prisma

generator client {
  provider = "prisma-client-js"
  output   = "../src/lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPERADMIN
  ADMIN
  TECHNICIAN
  USER
  GUEST
}

enum PoleStatus {
  ACTIVE
  FAULTY
  UNDER_MAINTENANCE
  DECOMMISSIONED
}

enum FaultType {
  NO_POWER
  FLICKERING
  DAMAGED_FIXTURE
  VANDALISM
  OTHER
}

enum ReportStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum WorkOrderStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CANCELLED
}

model User {
  id            String   @id @default(cuid())
  
  // Personal Info
  firstName     String
  middleName    String?
  lastName      String
  dob           DateTime?
  gender        String?
  
  // Contact & Auth
  email         String   @unique
  phone         String
  passwordHash  String
  
  // Location
  region        String
  province      String?  
  city          String
  barangay      String
  streetAddress String?

  role          Role     @default(USER)
  createdAt     DateTime @default(now())

  // Relations
  faultReports       FaultReport[]   @relation("ReportedBy")
  workOrdersAssigned WorkOrder[]     @relation("AssignedTo")
  workOrdersCreated  WorkOrder[]     @relation("AssignedBy")
  statusLogs         StatusLog[]
  searchHistory      SearchHistory[]
  notifications      Notification[]
  inventoryLogs      InventoryLog[]
}

model Pole {
  id          String     @id @default(cuid())
  poleCode    String     @unique
  address     String
  barangay    String
  latitude    Float
  longitude   Float
  status      PoleStatus @default(ACTIVE)
  installedAt DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  faultReports FaultReport[]
  statusLogs   StatusLog[]
}

model FaultReport {
  id           String       @id @default(cuid())
  pole         Pole         @relation(fields: [poleId], references: [id])
  poleId       String
  reportedBy   User         @relation("ReportedBy", fields: [reportedById], references: [id])
  reportedById String
  description  String
  faultType    FaultType
  status       ReportStatus @default(OPEN)
  reportedAt   DateTime     @default(now())

  workOrder WorkOrder?
}

model WorkOrder {
  id              String          @id @default(cuid())
  faultReport     FaultReport     @relation(fields: [faultReportId], references: [id])
  faultReportId   String          @unique
  assignedTo      User?           @relation("AssignedTo", fields: [assignedToId], references: [id])
  assignedToId    String?
  assignedBy      User            @relation("AssignedBy", fields: [assignedById], references: [id])
  assignedById    String
  status          WorkOrderStatus @default(PENDING)
  assignedAt      DateTime        @default(now())
  resolvedAt      DateTime?
  resolutionNotes String?
}

model StatusLog {
  id          String     @id @default(cuid())
  pole        Pole       @relation(fields: [poleId], references: [id])
  poleId      String
  changedBy   User       @relation(fields: [changedById], references: [id])
  changedById String
  fromStatus  PoleStatus
  toStatus    PoleStatus
  changedAt   DateTime   @default(now())
  reason      String?
}

model SearchHistory {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  title       String
  description String
  lat         Float?
  lng         Float?
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, read, createdAt])
}

model InventoryItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  sku         String   @unique
  quantity    Int      @default(0)
  unit        String   @default("pcs")
  minStock    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  logs        InventoryLog[]
}

model InventoryLog {
  id              String        @id @default(cuid())
  item            InventoryItem @relation(fields: [itemId], references: [id])
  itemId          String
  user            User          @relation(fields: [userId], references: [id])
  userId          String
  change          Int           // positive = added, negative = used
  note            String?
  createdAt       DateTime      @default(now())

  @@index([itemId, createdAt])
}