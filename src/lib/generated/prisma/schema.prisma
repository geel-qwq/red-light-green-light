generator client {
  provider = "prisma-client-js"
  output   = "../src/lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String          @id @default(cuid())
  email              String          @unique
  passwordHash       String
  role               Role            @default(USER)
  createdAt          DateTime        @default(now())
  barangay           String
  city               String
  dob                DateTime?
  firstName          String
  gender             String?
  lastName           String
  middleName         String?
  phone              String
  province           String?
  region             String
  streetAddress      String?
  faultReports       FaultReport[]   @relation("ReportedBy")
  inventoryLogs      InventoryLog[]
  notifications      Notification[]
  searchHistory      SearchHistory[]
  statusLogs         StatusLog[]
  workOrdersCreated  WorkOrder[]     @relation("AssignedBy")
  workOrdersAssigned WorkOrder[]     @relation("AssignedTo")
}

model Pole {
  id           String        @id @default(cuid())
  poleCode     String        @unique
  address      String
  barangay     String
  latitude     Float
  longitude    Float
  status       PoleStatus    @default(ACTIVE)
  installedAt  DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  faultReports FaultReport[]
  statusLogs   StatusLog[]
}

model FaultReport {
  id           String       @id @default(cuid())
  poleId       String
  reportedById String
  description  String
  faultType    FaultType
  status       ReportStatus @default(OPEN)
  reportedAt   DateTime     @default(now())
  pole         Pole         @relation(fields: [poleId], references: [id])
  reportedBy   User         @relation("ReportedBy", fields: [reportedById], references: [id])
  workOrder    WorkOrder?
}

model WorkOrder {
  id              String          @id @default(cuid())
  faultReportId   String          @unique
  assignedToId    String?
  assignedById    String
  status          WorkOrderStatus @default(PENDING)
  assignedAt      DateTime        @default(now())
  resolvedAt      DateTime?
  resolutionNotes String?
  assignedBy      User            @relation("AssignedBy", fields: [assignedById], references: [id])
  assignedTo      User?           @relation("AssignedTo", fields: [assignedToId], references: [id])
  faultReport     FaultReport     @relation(fields: [faultReportId], references: [id])
}

model StatusLog {
  id          String     @id @default(cuid())
  poleId      String
  changedById String
  fromStatus  PoleStatus
  toStatus    PoleStatus
  changedAt   DateTime   @default(now())
  reason      String?
  changedBy   User       @relation(fields: [changedById], references: [id])
  pole        Pole       @relation(fields: [poleId], references: [id])
}

model SearchHistory {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String
  lat         Float?
  lng         Float?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  usedAt    DateTime?

  @@index([email, token])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, read, createdAt])
}

model InventoryItem {
  id          String         @id @default(cuid())
  name        String
  description String?
  sku         String         @unique
  quantity    Int            @default(0)
  unit        String         @default("pcs")
  minStock    Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  logs        InventoryLog[]
}

model InventoryLog {
  id        String        @id @default(cuid())
  itemId    String
  userId    String
  change    Int
  note      String?
  createdAt DateTime      @default(now())
  item      InventoryItem @relation(fields: [itemId], references: [id])
  user      User          @relation(fields: [userId], references: [id])

  @@index([itemId, createdAt])
}

enum Role {
  SUPERADMIN
  ADMIN
  TECHNICIAN
  USER
  GUEST
}

enum PoleStatus {
  ACTIVE
  FAULTY
  UNDER_MAINTENANCE
  DECOMMISSIONED
}

enum FaultType {
  NO_POWER
  FLICKERING
  DAMAGED_FIXTURE
  VANDALISM
  OTHER
}

enum ReportStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum WorkOrderStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CANCELLED
}
